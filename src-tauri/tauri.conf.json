{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quill",
  "version": "1.0.0",
  "identifier": "com.dog.quill",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Quill",
        "width": 800,
        "height": 600,
        "minWidth": 850,
        "minHeight": 650,
        "center": true,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2Mzg4RTQyNTk5MzBBRDQKUldUVUNwTlpRbzQ0dGlaWWdKa3pvN3YvQXYxWERwN0lMTTlrUWdwcXIwaTlsamxKRkJ3SXhFWUwK",
      "endpoints": ["https://raw.githubusercontent.com/Elixir-Piloting/quill/main/update.json"]
    }
  }
}
